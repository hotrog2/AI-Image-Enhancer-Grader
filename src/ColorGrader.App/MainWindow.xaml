<Window x:Class="ColorGrader.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Color Grader"
        Width="1720"
        Height="1020"
        MinWidth="1440"
        MinHeight="860"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,18"
                Padding="24"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="32" FontWeight="SemiBold" Text="Color Grader" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Offline photo enhancement for fast client work: import a folder, build a look, refine only what matters, then export." />
                    <Border Margin="0,14,0,0"
                            Padding="12,10"
                            Background="{StaticResource AccentMutedBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       FontWeight="SemiBold"
                                       Text="Workflow" />
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       Text="1. Pick a photo   2. Render the quick pass   3. Fine-tune or export" />
                        </DockPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Width="150"
                            Margin="0,0,12,0"
                            Command="{Binding RefreshLibraryCommand}"
                            Content="Refresh Catalog"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Width="150"
                            Command="{Binding ImportFolderCommand}"
                            Content="Import Folder"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,18,0"
                    Padding="18"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="Library" />
                        <Button MinWidth="138"
                                HorizontalAlignment="Right"
                                Command="{Binding DeleteSelectedAssetCommand}"
                                Content="Remove from Library"
                                Style="{StaticResource DangerButtonStyle}" />
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,6,0,14"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding CatalogSummary}" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding LibraryItems}"
                             SelectedItem="{Binding SelectedLibraryItem, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12"
                                        Style="{StaticResource RaisedCardBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="78"
                                                Height="78"
                                                Background="#10000000"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding Kind}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding FilePath}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,18,0"
                    Padding="18"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Editor" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="{Binding SelectedAssetSummary}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="12,10"
                                Background="{StaticResource PanelRaisedBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding ConfidenceText}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding PreviewNotice}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            Padding="14"
                            Style="{StaticResource RaisedCardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    MinWidth="122"
                                    Click="EnterCropModeButton_OnClick"
                                    Content="Start Crop"
                                    Style="{StaticResource PrimaryButtonStyle}" />

                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Text="Straighten" />
                                <Slider Margin="0,6,0,0"
                                        Minimum="-15"
                                        Maximum="15"
                                        Value="{Binding StraightenAngle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        VerticalAlignment="Center">
                                <Button MinWidth="110"
                                        Margin="0,0,0,8"
                                        Command="{Binding ResetCropStraightenCommand}"
                                        Content="Reset Crop"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <TextBlock Width="220"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Open the Enhanced preview, then click-drag to draw a crop box. Drag inside the box to move it."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl x:Name="EditorPreviewTabs" Grid.Row="2" Margin="0,18,0,0">
                        <TabItem Header="Compare">
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Padding="8"
                                        Background="{StaticResource PreviewChromeBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Grid>
                                        <Image Source="{Binding OriginalPreview}" Stretch="Uniform" />
                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="12"
                                                Padding="10,6"
                                                Background="#CC111418"
                                                CornerRadius="999">
                                            <TextBlock Foreground="White" Text="Original" />
                                        </Border>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#90FFFFFF"
                                                   Text="Original preview" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="8"
                                        Background="{StaticResource PreviewChromeBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Grid>
                                        <Image Source="{Binding EnhancedPreview}" Stretch="Uniform" />
                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="12"
                                                Padding="10,6"
                                                Background="#CCC66B3D"
                                                CornerRadius="999">
                                            <TextBlock Foreground="White" Text="Enhanced" />
                                        </Border>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#90FFFFFF"
                                                   Text="Enhanced preview" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Original">
                            <Border Margin="0,8,0,0"
                                    Padding="8"
                                    Background="{StaticResource PreviewChromeBrush}"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <Grid>
                                    <Image Source="{Binding OriginalPreview}" Stretch="Uniform" />
                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="12"
                                            Padding="10,6"
                                            Background="#CC111418"
                                            CornerRadius="999">
                                        <TextBlock Foreground="White" Text="Original" />
                                    </Border>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#90FFFFFF"
                                               Text="Original preview" />
                                </Grid>
                            </Border>
                        </TabItem>
                        <TabItem Header="Enhanced">
                            <Border Margin="0,8,0,0"
                                    Padding="8"
                                    Background="{StaticResource PreviewChromeBrush}"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <Grid x:Name="EnhancedPreviewHost"
                                      SizeChanged="EnhancedPreviewHost_OnSizeChanged"
                                      PreviewMouseLeftButtonDown="EnhancedPreviewHost_OnPreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="EnhancedPreviewHost_OnPreviewMouseLeftButtonUp"
                                      PreviewMouseMove="EnhancedPreviewHost_OnPreviewMouseMove"
                                      PreviewMouseWheel="EnhancedPreviewHost_OnPreviewMouseWheel">
                                    <Image x:Name="EnhancedPreviewImage" Source="{Binding EnhancedPreview}" Stretch="Uniform" />
                                    <Canvas x:Name="EnhancedOverlayCanvas"
                                            IsHitTestVisible="False">
                                        <Rectangle x:Name="CropOverlayRectangle"
                                                   Stroke="#FFE8C76A"
                                                   StrokeThickness="2"
                                                   RadiusX="8"
                                                   RadiusY="8"
                                                   Visibility="Collapsed" />
                                        <Ellipse x:Name="LocalizedMaskEllipse"
                                                 Stroke="#FF6AD7B3"
                                                 StrokeThickness="2"
                                                 StrokeDashArray="4,3"
                                                 Visibility="Collapsed" />
                                        <Line x:Name="LocalizedMaskLine"
                                              Stroke="#FF6AD7B3"
                                              StrokeThickness="3"
                                              StrokeDashArray="6,4"
                                              Visibility="Collapsed" />
                                        <Ellipse x:Name="LocalizedMaskCenterHandle"
                                                 Width="12"
                                                 Height="12"
                                                 Fill="#FF6AD7B3"
                                                 Stroke="#FF0E1B20"
                                                 StrokeThickness="1"
                                                 Visibility="Collapsed" />
                                    </Canvas>
                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="12"
                                            Padding="10,6"
                                            Background="#CCC66B3D"
                                            CornerRadius="999">
                                        <TextBlock Foreground="White" Text="Enhanced" />
                                    </Border>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#90FFFFFF"
                                               Text="Enhanced preview" />
                                </Grid>
                            </Border>
                        </TabItem>
                    </TabControl>

                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="14"
                                Style="{StaticResource RaisedCardBorderStyle}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Why this suggestion" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding SuggestionRationale}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="14"
                                Style="{StaticResource RaisedCardBorderStyle}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="AI Mask Backend" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding InferenceStatusText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Enhance" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="Use the quick pass first. Everything else here is for steering, cleanup, saving, and export." />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,18,0,18"
                            Padding="16"
                            Style="{StaticResource RaisedCardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <UniformGrid Columns="2" Rows="2">
                                <Button Margin="0,0,10,10"
                                        Command="{Binding EnhanceCommand}"
                                        Content="Render"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Margin="0,0,0,10"
                                        Command="{Binding AcceptCommand}"
                                        Content="Accept"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Margin="0,0,10,0"
                                        Command="{Binding DeclineCommand}"
                                        Content="Decline"
                                        Style="{StaticResource DangerButtonStyle}" />
                                <Button Margin="0,0,0,0"
                                        Command="{Binding ResetFineTuneCommand}"
                                        Content="Reset Sliders"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </UniformGrid>

                            <Border Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Padding="12"
                                    Background="#14000000"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Current Session" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="{Binding StatusText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               FontWeight="SemiBold"
                                               Text="Visible Retry Modes" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Use these to force a different pass instead of hoping Decline lands somewhere new."
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Margin="0,0,10,10"
                                                Command="{Binding RetryCommand}"
                                                CommandParameter="Auto"
                                                Content="Auto Retry"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Margin="0,0,10,10"
                                                Command="{Binding RetryCommand}"
                                                CommandParameter="Brighter"
                                                Content="Brighter"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Margin="0,0,10,10"
                                                Command="{Binding RetryCommand}"
                                                CommandParameter="Cleaner"
                                                Content="Cleaner"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Margin="0,0,10,10"
                                                Command="{Binding RetryCommand}"
                                                CommandParameter="Warmer"
                                                Content="Warmer"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Margin="0,0,10,10"
                                                Command="{Binding RetryCommand}"
                                                CommandParameter="Sharper"
                                                Content="Sharper"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </WrapPanel>
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="{Binding SelectedRetryMode, StringFormat=Active retry mode: {0}}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="2">
                        <TabItem Header="Quick">
                            <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Features" />
                                            <TextBlock Margin="0,6,0,12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Choose what the one-click pass is allowed to adjust."
                                                       TextWrapping="Wrap" />
                                            <CheckBox IsChecked="{Binding AutoExposure}" Content="Auto exposure" />
                                            <CheckBox IsChecked="{Binding WhiteBalance}" Content="White balance" />
                                            <CheckBox IsChecked="{Binding Contrast}" Content="Contrast shaping" />
                                            <CheckBox IsChecked="{Binding ToneCurve}" Content="Tone curve and color pop" />
                                            <CheckBox IsChecked="{Binding SkinTone}" Content="Skin finish" />
                                            <CheckBox IsChecked="{Binding Denoise}" Content="Denoise" />
                                            <CheckBox IsChecked="{Binding Sharpen}" Content="Sharpen" />
                                            <CheckBox IsChecked="{Binding Upscale}" Content="Upscale preview" />
                                            <CheckBox IsChecked="{Binding QualityRestore}" Content="AI quality restore" />
                                            <CheckBox IsChecked="{Binding StyleLearning}" Content="Blend accepted style history" />

                                            <TextBlock Margin="0,14,0,6" Text="Enhancement strength" />
                                            <Slider Minimum="0"
                                                    Maximum="1"
                                                    TickFrequency="0.05"
                                                    Value="{Binding EnhancementStrength}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding EnhancementStrength, StringFormat=Strength {0:P0}}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Style Profile" />
                                            <TextBlock Margin="0,6,0,12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Train separate looks for different shoots, or use the whole catalog as shared history."
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="Profile name" />
                                            <TextBox Margin="0,6,0,12"
                                                     Text="{Binding NewStyleProfileName, UpdateSourceTrigger=PropertyChanged}" />

                                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                                <Button Margin="0,0,10,10"
                                                        Command="{Binding SaveStyleProfileCommand}"
                                                        Content="Save Profile"
                                                        Style="{StaticResource PrimaryButtonStyle}" />
                                                <Button Margin="0,0,0,10"
                                                        Command="{Binding UseCatalogStyleHistoryCommand}"
                                                        Content="Use Catalog History"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Margin="0,0,10,0"
                                                        Command="{Binding DeleteSelectedStyleProfileCommand}"
                                                        Content="Delete Selected"
                                                        Style="{StaticResource DangerButtonStyle}" />
                                            </UniformGrid>

                                            <ListBox ItemsSource="{Binding StyleProfiles}"
                                                     SelectedItem="{Binding SelectedStyleProfile, Mode=TwoWay}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10"
                                                                Background="#14000000"
                                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="14">
                                                            <StackPanel>
                                                                <DockPanel>
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding Name}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock HorizontalAlignment="Right"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               Text="{Binding AcceptedCount, StringFormat={}{0} accepted}" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding DeclinedCount, StringFormat={}{0} declined}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding LastFeedbackAt, StringFormat=Last example {0:g}, TargetNullValue=No examples yet}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Adjust">
                            <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,12">
                                                <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Text="Fine Tune" />
                                                <Button HorizontalAlignment="Right"
                                                        Command="{Binding ResetFineTuneCommand}"
                                                        Content="Reset"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </DockPanel>

                                            <TextBlock Text="Exposure" />
                                            <Slider Minimum="-0.5" Maximum="0.8" Value="{Binding ManualExposure}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualExposure, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Contrast" />
                                            <Slider Minimum="-0.3" Maximum="0.5" Value="{Binding ManualContrast}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualContrast, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Warmth" />
                                            <Slider Minimum="-0.2" Maximum="0.2" Value="{Binding ManualWarmth}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualWarmth, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Saturation" />
                                            <Slider Minimum="-0.3" Maximum="0.5" Value="{Binding ManualSaturation}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualSaturation, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Vibrance" />
                                            <Slider Minimum="-0.3" Maximum="0.5" Value="{Binding ManualVibrance}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualVibrance, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Highlights" />
                                            <Slider Minimum="-0.2" Maximum="0.5" Value="{Binding ManualHighlightRecovery}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualHighlightRecovery, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Shadows" />
                                            <Slider Minimum="-0.2" Maximum="0.5" Value="{Binding ManualShadowLift}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualShadowLift, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Skin softening" />
                                            <Slider Minimum="0" Maximum="0.4" Value="{Binding ManualSkinSoftening}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualSkinSoftening, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Denoise" />
                                            <Slider Minimum="0" Maximum="0.4" Value="{Binding ManualDenoise}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualDenoise, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Sharpen" />
                                            <Slider Minimum="0" Maximum="0.4" Value="{Binding ManualSharpen}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualSharpen, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,18,0,0" FontSize="15" FontWeight="SemiBold" Text="Quality Restore" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Use this for soft, compressed, or low-quality images. It targets blur, blockiness, and synthetic-looking texture."
                                                       TextWrapping="Wrap" />

                                            <TextBlock Margin="0,12,0,0" Text="Detail recovery" />
                                            <Slider Minimum="0" Maximum="0.8" Value="{Binding ManualDetailRecovery}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualDetailRecovery, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Deblur" />
                                            <Slider Minimum="0" Maximum="0.8" Value="{Binding ManualDeblur}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualDeblur, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Artifact reduction" />
                                            <Slider Minimum="0" Maximum="0.8" Value="{Binding ManualArtifactReduction}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualArtifactReduction, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Realism boost" />
                                            <Slider Minimum="0" Maximum="0.6" Value="{Binding ManualRealismBoost}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ManualRealismBoost, StringFormat={}{0:0.00}}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,12">
                                                <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Text="Crop and Straighten" />
                                                <Button HorizontalAlignment="Right"
                                                        Command="{Binding ResetCropStraightenCommand}"
                                                        Content="Reset"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </DockPanel>

                                            <TextBlock Text="Straighten" />
                                            <Slider Minimum="-15" Maximum="15" Value="{Binding StraightenAngle}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding StraightenAngle, StringFormat={}{0:+0.0;-0.0;0.0} deg}" />

                                            <TextBlock Margin="0,12,0,6" Text="Canvas drag tool" />
                                            <ComboBox ItemsSource="{Binding CanvasEditorTools}"
                                                      SelectedItem="{Binding SelectedCanvasEditorTool}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Use the Enhanced tab to drag the active tool over the image. Crop uses click-drag. Mouse wheel only changes localized mask size."
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,12">
                                                <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Text="Localized Mask" />
                                                <Button HorizontalAlignment="Right"
                                                        Command="{Binding ResetLocalizedMaskCommand}"
                                                        Content="Reset"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </DockPanel>

                                            <CheckBox IsChecked="{Binding LocalizedMaskEnabled}" Content="Enable localized mask" />

                                            <TextBlock Margin="0,12,0,6" Text="Mask type" />
                                            <ComboBox ItemsSource="{Binding LocalizedMaskKinds}"
                                                      SelectedItem="{Binding SelectedLocalizedMaskKind}" />

                                            <CheckBox Margin="0,10,0,0"
                                                      IsChecked="{Binding InvertLocalizedMask}"
                                                      Content="Invert mask" />

                                            <TextBlock Margin="0,12,0,0" Text="Center X" />
                                            <Slider Minimum="0" Maximum="1" Value="{Binding LocalizedMaskCenterX}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedMaskCenterX, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Center Y" />
                                            <Slider Minimum="0" Maximum="1" Value="{Binding LocalizedMaskCenterY}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedMaskCenterY, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Width" />
                                            <Slider Minimum="0.15" Maximum="1" Value="{Binding LocalizedMaskWidth}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedMaskWidth, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Height" />
                                            <Slider Minimum="0.15" Maximum="1" Value="{Binding LocalizedMaskHeight}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedMaskHeight, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Feather" />
                                            <Slider Minimum="0.02" Maximum="0.95" Value="{Binding LocalizedMaskFeather}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedMaskFeather, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Angle" />
                                            <Slider Minimum="-180" Maximum="180" Value="{Binding LocalizedMaskAngle}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedMaskAngle, StringFormat={}{0:+0;-0;0} deg}" />

                                            <TextBlock Margin="0,10,0,0" Text="Intensity" />
                                            <Slider Minimum="0" Maximum="1" Value="{Binding LocalizedMaskIntensity}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedMaskIntensity, StringFormat={}{0:P0}}" />

                                            <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Mask Adjustments" />

                                            <TextBlock Margin="0,10,0,0" Text="Exposure" />
                                            <Slider Minimum="-0.5" Maximum="0.8" Value="{Binding LocalizedExposure}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedExposure, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Contrast" />
                                            <Slider Minimum="-0.3" Maximum="0.5" Value="{Binding LocalizedContrast}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedContrast, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Warmth" />
                                            <Slider Minimum="-0.2" Maximum="0.2" Value="{Binding LocalizedWarmth}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedWarmth, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Saturation" />
                                            <Slider Minimum="-0.3" Maximum="0.5" Value="{Binding LocalizedSaturation}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedSaturation, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Vibrance" />
                                            <Slider Minimum="-0.3" Maximum="0.5" Value="{Binding LocalizedVibrance}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedVibrance, StringFormat={}{0:+0.00;-0.00;0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Skin softening" />
                                            <Slider Minimum="0" Maximum="0.5" Value="{Binding LocalizedSkinSoftening}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedSkinSoftening, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Denoise" />
                                            <Slider Minimum="0" Maximum="0.5" Value="{Binding LocalizedDenoise}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedDenoise, StringFormat={}{0:0.00}}" />

                                            <TextBlock Margin="0,10,0,0" Text="Sharpen" />
                                            <Slider Minimum="0" Maximum="0.5" Value="{Binding LocalizedSharpen}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding LocalizedSharpen, StringFormat={}{0:0.00}}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Presets">
                            <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Saved Presets" />
                                            <TextBlock Margin="0,6,0,12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Save the current setup, including crop and masks, then reuse it on the next image."
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="Preset name" />
                                            <TextBox Margin="0,6,0,12"
                                                     Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}" />

                                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                                <Button Margin="0,0,10,10"
                                                        Command="{Binding SavePresetCommand}"
                                                        Content="Save Current"
                                                        Style="{StaticResource PrimaryButtonStyle}" />
                                                <Button Margin="0,0,0,10"
                                                        Command="{Binding ApplySelectedPresetCommand}"
                                                        Content="Apply Selected"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Margin="0,0,10,0"
                                                        Command="{Binding DeleteSelectedPresetCommand}"
                                                        Content="Delete Selected"
                                                        Style="{StaticResource DangerButtonStyle}" />
                                            </UniformGrid>

                                            <ListBox ItemsSource="{Binding Presets}"
                                                     SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10"
                                                                Background="#14000000"
                                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="14">
                                                            <StackPanel>
                                                                <DockPanel>
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding Name}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock HorizontalAlignment="Right"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               Text="{Binding Strength, StringFormat={}{0:P0}}" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding FeatureMask}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding CreatedAt, StringFormat=Saved {0:g}}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Export">
                            <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Batch Export" />
                                            <TextBlock Margin="0,6,0,12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Choose output settings once, then export the current image or the full catalog."
                                                       TextWrapping="Wrap" />

                                            <Button Margin="0,0,0,10"
                                                    Command="{Binding ChooseExportFolderCommand}"
                                                    Content="Choose Export Folder"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding ExportFolder}"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Margin="0,16,0,6" Text="Format" />
                                            <ComboBox ItemsSource="{Binding ExportFormats}"
                                                      SelectedItem="{Binding SelectedExportFormat}" />

                                            <TextBlock Margin="0,12,0,6" Text="Long edge pixels" />
                                            <TextBox Text="{Binding ExportLongEdgePixels, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock Margin="0,12,0,6" Text="JPEG quality" />
                                            <TextBox Text="{Binding JpegQuality, UpdateSourceTrigger=PropertyChanged}" />

                                            <UniformGrid Columns="2" Margin="0,16,0,12">
                                                <Button Margin="0,0,10,10"
                                                        Command="{Binding ExportSelectedCommand}"
                                                        Content="Export Selected"
                                                        Style="{StaticResource PrimaryButtonStyle}" />
                                                <Button Margin="0,0,0,10"
                                                        Command="{Binding ExportAllCommand}"
                                                        Content="Export Entire Catalog"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Margin="0,0,10,0"
                                                        Command="{Binding CancelExportsCommand}"
                                                        Content="Cancel Exports"
                                                        Style="{StaticResource DangerButtonStyle}" />
                                            </UniformGrid>

                                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                       Text="{Binding ExportProgressText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Export Queue" />
                                            <ListBox Margin="0,12,0,0"
                                                     ItemsSource="{Binding ExportQueueItems}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10"
                                                                Background="#14000000"
                                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="14">
                                                            <StackPanel>
                                                                <TextBlock FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" Text="{Binding Status}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding Detail}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="16"
                                            Style="{StaticResource RaisedCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Recent Exports" />
                                            <ListBox Margin="0,12,0,0"
                                                     ItemsSource="{Binding RecentExports}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10"
                                                                Background="#14000000"
                                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="14">
                                                            <StackPanel>
                                                                <DockPanel>
                                                                    <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock HorizontalAlignment="Right"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               Text="{Binding TimestampText}" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" Text="{Binding Status}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding Detail}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Padding="14,10"
                Background="#12000000"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           FontWeight="SemiBold"
                           Text="Local-first | Offline | Windows" />
                <TextBlock HorizontalAlignment="Right"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="AMD-friendly architecture: deterministic grading now, export queue live, RAW proxy fallback in place." />
            </DockPanel>
        </Border>
    </Grid>
</Window>
